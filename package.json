{
  "name": "toonflow-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:frontend": "pnpm --filter toonflow_web dev",
    "dev:backend": "pnpm --filter toonflow dev",
    "build:frontend": "pnpm --filter toonflow_web build",
    "build:backend": "pnpm --filter toonflow build"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
