{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "target": "ESNext",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "build",
    "noImplicitAny": true,
    "strict": true,
    "sourceMap": false,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "node"
    ],
    "incremental": false,
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "data",
    "dist",
    "build",
    "backup"
  ]
}