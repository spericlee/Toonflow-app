{
  "name": "toonflow",
  "version": "1.2.0",
  "description": "Toonflow 是一款 AI 短剧漫剧工具，能够利用 AI 技术将小说自动转化为剧本，并结合 AI 生成的图片和视频，实现高效的短剧创作。",
  "author": "HBAI-Ltd <ltlctools@outlook.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/HBAI-Ltd/Toonflow-app#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HBAI-Ltd/Toonflow-app.git"
  },
  "bugs": {
    "url": "https://github.com/HBAI-Ltd/Toonflow-app/issues",
    "email": "ltlctools@outlook.com"
  },
  "main": "build/electron/main.js",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "dev": "nodemon --inspect --exec tsx src/app.ts",
    "dev:gui": "chcp 65001 && electronmon -r tsx scripts/main.ts",
    "dev:gui-vite": "cross-env VITE_DEV=1 electronmon -r tsx scripts/main.ts",
    "start": "cross-env NODE_ENV=prod node build/server/app.cjs",
    "lint": "tsc --noEmit",
    "build": "cross-env NODE_ENV=prod tsx scripts/build.ts",
    "dist": "cross-env NODE_ENV=prod PACK=1 tsx scripts/build.ts",
    "debug:ai": "npx @ai-sdk/devtools",
    "license": "node scripts/license.ts",
    "vendor2json": "node scripts/vendor2json.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/deepseek": "^2.0.17",
    "@ai-sdk/devtools": "^0.0.11",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/openai-compatible": "^2.0.27",
    "@ai-sdk/xai": "^3.0.47",
    "ai": "^6.0.67",
    "axios": "^1.13.2",
    "axios-retry": "^4.5.0",
    "bytenode": "^1.5.7",
    "compressing": "^2.1.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "form-data": "^4.0.5",
    "graphlib": "^2.1.8",
    "is-path-inside": "^4.0.0",
    "js-md5": "^0.8.3",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "morgan": "^1.10.1",
    "p-limit": "^7.3.0",
    "qwen-ai-provider-v5": "^2.1.0",
    "serialize-error": "^13.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sucrase": "^3.35.1",
    "teen_process": "^4.1.3",
    "uuid": "^13.0.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "vm2": "^3.10.5",
    "wait-port": "^1.1.0",
    "zhipu-ai-provider": "^0.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@pnpm/dependency-path": "^1001.1.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/graphlib": "^2.1.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/license-checker": "^25.0.6",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "app-builder-lib": "^26.8.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electronmon": "^2.0.4",
    "esbuild": "^0.28.0",
    "license-checker": "^25.0.1",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  }
}