{
  "extends": ["@vue/tsconfig/tsconfig.dom.json", "../../tsconfig.base.json"],
  "include": ["src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts", "src/**/__tests__/*"]
}