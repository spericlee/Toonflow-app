{
  "name": "@toonflow/app",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon --inspect --exec tsx src/app.ts",
    "prod": "cross-env NODE_ENV=prod nodemon --inspect --exec tsx src/app.ts",
    "electron": "cross-env NODE_ENV=electron nodemon --inspect --exec tsx src/app.ts",
    "gui:dev": "chcp 65001 && cross-env NODE_ENV=dev electronmon -r tsx scripts/main.ts",
    "dist": "cross-env NODE_ENV=prod tsx ./scripts/dist.ts",
    "pack": "cross-env NODE_ENV=prod tsx ./scripts/pack.ts",
    "debug:ai": "npx @ai-sdk/devtools",
    "vendor2json": "node scripts/vendor2json.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/utils/db/seed.ts",
    "db:pull": "drizzle-kit pull --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/deepseek": "^2.0.17",
    "@ai-sdk/devtools": "^0.0.11",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/openai-compatible": "^2.0.27",
    "@ai-sdk/xai": "^3.0.47",
    "ai": "^6.0.67",
    "axios": "^1.13.2",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.10.0",
    "bytenode": "^1.5.7",
    "compressing": "^2.1.0",
    "conf": "^15.1.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "form-data": "^4.0.5",
    "graphlib": "^2.1.8",
    "http-proxy": "^1.18.1",
    "is-path-inside": "^4.0.0",
    "js-md5": "^0.8.3",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "morgan": "^1.10.1",
    "p-limit": "^7.3.0",
    "qwen-ai-provider-v5": "^2.1.0",
    "serialize-error": "^13.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sucrase": "^3.35.1",
    "teen_process": "^4.1.3",
    "uuid": "^13.0.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "vm2": "^3.10.5",
    "wait-port": "^1.1.0",
    "zhipu-ai-provider": "^0.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@pnpm/dependency-path": "^1001.1.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/graphlib": "^2.1.12",
    "@types/http-proxy": "^1.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/license-checker": "^25.0.6",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "app-builder-lib": "^26.8.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "esbuild": "^0.28.0",
    "license-checker": "^25.0.1",
